# API Authentication
AEGIS_API_KEY=                  # if set, protects mutating API endpoints (POST/PUT/DELETE)
AEGIS_ENV=development           # development | production

# Gateway
AEGIS_ADDR=:8080
AEGIS_BASE_URL=http://localhost:8080
AEGIS_DB_PATH=./data/gateway.db
AEGIS_TELEGRAM_TOKEN=
AEGIS_DISCORD_TOKEN=
AEGIS_DISCORD_APP_ID=

# Daemon
AEGIS_GATEWAY_URL=ws://localhost:8080/ws/daemon
AEGIS_DAEMON_ID=
AEGIS_DAEMON_TOKEN=
AEGIS_DAEMON_NAME=dev-machine
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
AEGIS_CLAUDE_MODEL=claude-sonnet-4-20250514
