# === Gateway (aegisd) ===

# API Authentication
AEGIS_API_KEY=                  # if set, protects mutating API endpoints (POST/PUT/DELETE)
AEGIS_ENV=development           # development | production

# Server
AEGIS_ADDR=:8080
AEGIS_BASE_URL=http://localhost:8080
AEGIS_DATABASE_URL=./data/gateway.db

# === Daemon (aegis-agent) ===
# These belong in the daemon machine's .env, NOT the gateway:

# AEGIS_GATEWAY_URL=ws://localhost:8080/ws/daemon
# AEGIS_DAEMON_ID=
# AEGIS_DAEMON_TOKEN=
# AEGIS_DAEMON_NAME=aegis-agent
# AEGIS_LOG_LEVEL=info
# AEGIS_WORKSPACES_ROOT=./workspaces
# AEGIS_AGENT_TIMEOUT=30m

# Agent harness API keys (daemon-side):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Optional daemon-side harness overrides:
# AEGIS_CLAUDE_PATH=claude
# AEGIS_CLAUDE_MODEL=claude-sonnet-4-20250514
# AEGIS_CODEX_PATH=codex
# AEGIS_CODEX_MODEL=
# AEGIS_GEMINI_PATH=gemini
# AEGIS_GEMINI_MODEL=
